# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/blanc

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer)
EMAIL_SERVICE=your-email-service-provider
EMAIL_USER=your-verified-email
EMAIL_PASSWORD=verified-email-password

# SMS (httpsms)
HTTPSMS_API_KEY=Api_key
HTTPSMS_FROM_NUMBER=verified-phone-number

# Frontend URL
FRONTEND_URL=http://localhost:5173